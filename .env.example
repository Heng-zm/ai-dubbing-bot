# Required secrets / infrastructure only
BOT_TOKEN=
ADMIN_IDS=123456789,987654321
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
REDIS_URL=redis://localhost:6379/0

# Debug only. Keep false in production.
ALLOW_START_WITHOUT_SUPABASE=false

# Render Web Service health server. Render provides PORT automatically.
ENABLE_HEALTH_SERVER=true
HEALTH_SERVER_HOST=0.0.0.0
HEALTH_SERVER_PORT=10000
DROP_PENDING_UPDATES=false

# Paths and binaries
TEMP_DIR=temp
TTS_CACHE_DIR=temp/tts_cache
FFMPEG_BINARY=ffmpeg
FFPROBE_BINARY=ffprobe
FFMPEG_PRESET=veryfast
FFMPEG_VIDEO_CRF=23
FFMPEG_MERGE_TIMEOUT_SECONDS=420

# Advanced retry/network defaults
REDIS_SOCKET_TIMEOUT_SECONDS=10
# Prevent Telegram getUpdates conflict when two copies accidentally run.
BOT_INSTANCE_LOCK_ENABLED=true
BOT_INSTANCE_LOCK_KEY=bot:polling:instance_lock
BOT_INSTANCE_LOCK_TTL_SECONDS=90
BOT_INSTANCE_LOCK_REFRESH_SECONDS=25
TASK_TTL_SECONDS=86400
TASK_LOCK_TTL_SECONDS=1800
WORKER_QUEUE_TIMEOUT_SECONDS=2
TELEGRAM_SEND_MAX_RETRIES=3
TELEGRAM_BROADCAST_DELAY_SECONDS=0.05
PROGRESS_EDIT_INTERVAL_SECONDS=2
PROGRESS_MIN_DELTA_PERCENT=3
TTS_MAX_RETRIES=3
TTS_RETRY_BASE_DELAY_SECONDS=3
EDGE_TTS_RATE=+0%
EDGE_TTS_VOLUME=+0%
EDGE_TTS_PITCH=+0Hz
EDGE_TTS_DELAY_SECONDS=6
EDGE_TTS_CONNECT_TIMEOUT=15
EDGE_TTS_RECEIVE_TIMEOUT=60
EDGE_TTS_PROXY=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus
AZURE_OUTPUT_FORMAT=audio-24khz-48kbitrate-mono-mp3
AZURE_USER_AGENT=ai-dubbing-bot
AZURE_TTS_TIMEOUT_SECONDS=60

# Bot operational settings below are now configured from Telegram:
# /admin → ⚙️ Settings
# - Max video duration
# - Max video size
# - Max SRT size
# - TTS provider/cache
# - Original/dubbed audio volume
# - Worker mode/count
# - Clean/failed file behavior
# - Clear queue on startup
# - Queue key
# - Watermark branding
# - Multi voice per character
# - Processing time estimate

# Recommended for latest bug-fix build
# Prevent old Redis jobs from using missing Render temp files after deploy/restart.
CLEAR_STALE_QUEUE_ON_START=true
# Keep failed files so Retry can work until Render restarts/cleans temp files.
KEEP_FAILED_FILES=true

# FFmpeg safety for Render
# If tasks still take too long during video merge, lower this or set watermark_render_mode=metadata in /admin settings.
