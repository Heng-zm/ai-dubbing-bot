BOT_TOKEN=
ADMIN_IDS=123456789,987654321
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
REDIS_URL=redis://localhost:6379/0

# Debug only. Keep false in production.
ALLOW_START_WITHOUT_SUPABASE=false

MAX_VIDEO_DURATION_SECONDS=60
MAX_VIDEO_SIZE_MB=50
MAX_SRT_SIZE_MB=2
MAX_SUBTITLE_CHARS=450
MIN_SUBTITLE_DURATION_SECONDS=0.20

KEEP_ORIGINAL_AUDIO=false
ORIGINAL_AUDIO_VOLUME=0.15
DUBBED_AUDIO_VOLUME=1.0
NORMALIZE_AUDIO=true

# Single Render service mode: process Redis queue inside the bot process.
IN_PROCESS_WORKER=true
IN_PROCESS_WORKER_COUNT=1

# Set true only if you deploy as Render Web Service and need to bind $PORT.
# If you deploy as Render Background Worker, keep false.
ENABLE_HEALTH_SERVER=false
HEALTH_SERVER_HOST=0.0.0.0
HEALTH_SERVER_PORT=10000
DROP_PENDING_UPDATES=false

REDIS_QUEUE_KEY=queue:dubbing
REDIS_SOCKET_TIMEOUT_SECONDS=10
TASK_TTL_SECONDS=86400
TASK_LOCK_TTL_SECONDS=1800
WORKER_QUEUE_TIMEOUT_SECONDS=2

TEMP_DIR=temp
CLEAN_SUCCESS_FILES=true
KEEP_FAILED_FILES=true
CLEANUP_ON_START=false
CLEANUP_OLD_TEMP_HOURS=24

TELEGRAM_SEND_MAX_RETRIES=3
TELEGRAM_BROADCAST_DELAY_SECONDS=0.05
PROGRESS_EDIT_INTERVAL_SECONDS=2
PROGRESS_MIN_DELTA_PERCENT=3

FFMPEG_BINARY=ffmpeg
FFPROBE_BINARY=ffprobe
FFMPEG_PRESET=veryfast
FFMPEG_VIDEO_CRF=23

# TTS provider:
# edge = free edge-tts only
# auto = edge first, then official Azure Speech if edge returns 403 and Azure keys are configured
# azure = official Azure Speech only
TTS_PROVIDER=edge
TTS_CACHE_ENABLED=true
TTS_CACHE_DIR=temp/tts_cache
TTS_MAX_RETRIES=3
TTS_RETRY_BASE_DELAY_SECONDS=3

# Edge TTS hardening for cloud hosts. Keep worker count 1 and add delay to reduce 403/rate limits.
EDGE_TTS_RATE=+0%
EDGE_TTS_VOLUME=+0%
EDGE_TTS_PITCH=+0Hz
EDGE_TTS_DELAY_SECONDS=6
EDGE_TTS_CONNECT_TIMEOUT=15
EDGE_TTS_RECEIVE_TIMEOUT=60
EDGE_TTS_PROXY=

# Optional official Microsoft Azure Speech fallback.
# Required only when TTS_PROVIDER=auto or TTS_PROVIDER=azure.
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus
AZURE_OUTPUT_FORMAT=audio-24khz-48kbitrate-mono-mp3
AZURE_USER_AGENT=ai-dubbing-bot
AZURE_TTS_TIMEOUT_SECONDS=60
